# Resend Email Service Configuration
# See RESEND_SETUP.md for detailed setup instructions

# Your Resend API key (get from https://resend.com/dashboard)
# Format: re_xxxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxxx

# The "from" email address (must be from your verified domain)
# Example: noreply@techieneighbor.net
RESEND_FROM_EMAIL=noreply@mail.techieneighbor.net

# The recipient email address for contact form submissions
# This is where you'll receive the messages
RESEND_TO_EMAIL=contact@techieneighbor.net

# Supabase Configuration
# See SUPABASE_SETUP.md for detailed setup instructions

# Your Supabase project URL (get from Project Settings → API)
# Format: https://xxxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Your Supabase anon/public key (get from Project Settings → API)
# This key is safe to use in the browser (protected by Row Level Security)
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service role key (get from Project Settings → API)
# ⚠️ KEEP THIS SECRET - Never expose to the client, only use server-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin Configuration
# The email address for the admin user account
ADMIN_EMAIL=admin@techieneighbor.net

# Klaviyo Configuration (for newsletter subscriber management)
# Get these from your Klaviyo account dashboard
KLAVIYO_API_KEY=pk_xxxxxxxxxxxxx
KLAVIYO_LIST_ID=xxxxxxxxxxxxx
